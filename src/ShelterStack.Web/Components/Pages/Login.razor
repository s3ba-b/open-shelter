@page "/login"
@layout EmptyLayout
@inject GatewayClient Gateway
@inject WebAuthenticationStateProvider Auth
@inject NavigationManager Navigation

<PageTitle>Sign in · ShelterStack</PageTitle>

<div class="auth">
    <aside class="auth-aside">
        <span class="brand">
            <span class="brand-mark">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11.5 12 4l9 7.5" /><path d="M5 10v9a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-9" /><path d="M9.5 21v-5a2.5 2.5 0 0 1 5 0v5" /></svg>
            </span>
            <span class="brand-name">ShelterStack<small>STAFF WORKSPACE</small></span>
        </span>

        <div class="auth-aside-body">
            <h2>Manage your shelter, all in one place.</h2>
            <p>Animals, adoptions, foster homes, and vet schedules — for your organization, kept private to your organization.</p>
            <ul class="auth-points">
                <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg> Your data is isolated from every other shelter</li>
                <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg> Roles for admins, staff, and volunteers</li>
                <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg> Free and open source, forever</li>
            </ul>
        </div>

        <p class="auth-foot">ShelterStack · AGPL-3.0</p>
    </aside>

    <main class="auth-main">
        <EditForm class="auth-form" Model="_model" OnValidSubmit="SignInAsync">
            <DataAnnotationsValidator />

            <h1>Sign in</h1>
            <p class="sub">Welcome back. Enter your credentials to open your workspace.</p>

            @if (_error is not null)
            {
                <div class="auth-error" role="alert">@_error</div>
            }

            <div class="field">
                <label for="email">Email</label>
                <InputText id="email" @bind-Value="_model.Email" type="email" placeholder="you@shelter.org" autocomplete="username" />
            </div>

            <div class="field">
                <label for="pw">Password</label>
                <InputText id="pw" @bind-Value="_model.Password" type="password" autocomplete="current-password" />
            </div>

            <button class="btn btn-primary btn-block" type="submit" disabled="@_busy">
                @(_busy ? "Signing in…" : "Sign in to workspace")
            </button>

            <p class="hint" style="margin-top:16px;text-align:center">
                Demo accounts: <span class="mono">admin@northside.example</span> ·
                <span class="mono">staff@riverside.example</span> — password <span class="mono">Demo123!</span>
            </p>
        </EditForm>
    </main>
</div>

@code {
    private readonly Credentials _model = new();
    private bool _busy;
    private string? _error;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    // Already signed in (e.g. navigated to /login by hand): skip straight to the app.
    protected override void OnInitialized()
    {
        if (Auth.AccessToken is not null)
        {
            Navigation.NavigateTo(SafeReturnTarget(), replace: true);
        }
    }

    private async Task SignInAsync()
    {
        _busy = true;
        _error = null;

        var token = await Gateway.LoginAsync(_model.Email, _model.Password, CancellationToken.None);
        if (token is null)
        {
            _error = "We couldn't sign you in. Check your email and password and try again.";
            _busy = false;
            return;
        }

        // Tenant/role/organization come from the token's claims; the email is carried for display.
        Auth.SignIn(token, _model.Email);
        Navigation.NavigateTo(SafeReturnTarget(), replace: true);
    }

    // Only honour a same-app relative return path, so a crafted ?returnUrl can't bounce the
    // signed-in user off to an external site.
    private string SafeReturnTarget() =>
        !string.IsNullOrEmpty(ReturnUrl) && !ReturnUrl.Contains("//", StringComparison.Ordinal)
            ? ReturnUrl
            : "";

    private sealed class Credentials
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;
    }
}
